void main() {
    vec2 fragCoord = gl_FragCoord.xy;
    // Create 16:9 widescreen coordinates centered on screen
    vec2 uv = (2.0 * fragCoord - iResolution.xy) / iResolution.y;
    uv.x *= 9.0/16.0;  // Scale to 16:9 aspect ratio

    // AUDIO SAMPLING (iChannel0 = audio input)
    // Threshold audio to remove noise floor (prevents constant red boost when silent)
    float bass = max(0.0, FFT(2) - AUDIO_THRESHOLD);      // Low frequencies
    float mid = max(0.0, FFT(10) - AUDIO_THRESHOLD);      // Mid frequencies
    float treble = max(0.0, FFT(20) - AUDIO_THRESHOLD);   // High frequencies
    float snd = (bass + mid + treble) / 3.0;  // Average

    // ============================================================
    // AUTOMATION: Calculate current stage and determine active effects
    // ============================================================
    int stage = calculateStage(iTime, bass);

    // Determine which effects are active based on mode and stage
    bool enable_spatial_warp = false;
    bool enable_wave_distortion = false;
    bool enable_radial_pulse = false;

    #if AUTOMATION_MODE == 0
        // Manual mode - use manual toggles
        enable_spatial_warp = (MANUAL_SPATIAL_WARP == 1);
        enable_wave_distortion = (MANUAL_WAVE_DISTORTION == 1);
        enable_radial_pulse = (MANUAL_RADIAL_PULSE == 1);
    #else
        // Automated mode - activate effects based on stage
        // Stage 0 (0-5s):     None (RED_TONE only)
        // Stage 1 (5-10s):    SPATIAL_WARP
        // Stage 2 (10-15s):   WAVE_DISTORTION (drop spatial)
        // Stage 3 (15-20s):   WAVE + RADIAL
        // Stage 4 (20-25s):   All 3 effects
        // Stage 5+ (25s+):    All 3 effects (sustained)

        if (stage == 1) {
            enable_spatial_warp = true;
        } else if (stage == 2) {
            enable_wave_distortion = true;
        } else if (stage == 3) {
            enable_wave_distortion = true;
            enable_radial_pulse = true;
        } else if (stage >= 4) {
            enable_spatial_warp = true;
            enable_wave_distortion = true;
            enable_radial_pulse = true;
        }
    #endif

    // Initialize z,w coordinates (trained with z=y, w=x swapped)
    vec2 zw = uv.yx;

    // ============================================================
    // EFFECT 1: SPATIAL WARP (Global coordinate modulation)
    // ============================================================
    if (enable_spatial_warp) {
        zw.x += sin(iTime * SPATIAL_WARP_Z_FREQUENCY) * bass * SPATIAL_WARP_Z_STRENGTH;
        zw.y += cos(iTime * SPATIAL_WARP_W_FREQUENCY) * mid * SPATIAL_WARP_W_STRENGTH;
    }

    // ============================================================
    // EFFECT 2: WAVE DISTORTION (Spatial waves - different regions react differently!)
    // ============================================================
    if (enable_wave_distortion) {
        // Create spatial waves that vary across the image
        // Bass affects horizontal waves, mid affects vertical, treble affects diagonal
        float wave_x = sin(uv.y * WAVE_FREQUENCY + iTime * WAVE_SPEED) * bass * WAVE_BASS_STRENGTH;
        float wave_y = cos(uv.x * WAVE_FREQUENCY + iTime * WAVE_SPEED * 1.3) * mid * WAVE_MID_STRENGTH;
        float wave_diag = sin((uv.x + uv.y) * WAVE_FREQUENCY * 0.7 + iTime * WAVE_SPEED * 0.8) * treble * WAVE_TREBLE_STRENGTH;

        zw.x += wave_x + wave_diag;
        zw.y += wave_y + wave_diag;
    }

    // ============================================================
    // EFFECT 3: RADIAL PULSE (Center-based pulsing)
    // ============================================================
    if (enable_radial_pulse) {
        float dist = length(uv);
        float radial = sin(dist * 5.0 - iTime * RADIAL_FREQUENCY) * snd * RADIAL_STRENGTH;
        zw += normalize(uv) * radial;
    }

    // Get color from 4D SIREN (x, y, z_modulated, w_modulated)
    vec3 col = getColor(vec4(uv, zw));

    // Convert from [-1, 1] to [0, 1]
    col = col * 0.5 + 0.5;

    // Clamp to valid range
    col = clamp(col, 0.0, 1.0);

    // ============================================================
    // EFFECT 4: RED TONE MODULATION (Color-based oscilloscope effect)
    // ⭐ ALWAYS ON - This effect is active in all modes and stages!
    // ============================================================
    // Detect red intensity (how much more red than green/blue)
    float red_intensity = col.r - max(col.g, col.b);
    float red_mask = smoothstep(RED_DETECTION_THRESHOLD, RED_DETECTION_SHARPNESS, red_intensity);

    // Calculate brightness modulation based on audio (oscilloscope-style)
    float brightness_mod = bass * RED_BASS_BRIGHTNESS +
                           mid * RED_MID_BRIGHTNESS +
                           treble * RED_TREBLE_BRIGHTNESS;

    // Apply modulation only to red channel (keeps it in shades of red)
    col.r += red_mask * brightness_mod;

    // Re-clamp after modulation
    col = clamp(col, 0.0, 1.0);

    fragColor = vec4(col, 1.0);
}
