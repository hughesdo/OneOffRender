// ============================================================
// AUDIO-REACTIVE AUTOMATION SYSTEM
// ============================================================
// This shader progressively activates effects over time, syncing with music!
//
// 🎵 AUTOMATION MODES:
//   0 = MANUAL      - You control effect toggles manually (edit ENABLE_* below)
//   1 = TIME_BASED  - Effects activate at fixed time intervals
//   2 = AUDIO_SMART - Effects activate based on bass hits OR time (HYBRID) ⭐
//
// 📊 STAGE PROGRESSION (Mode 1 or 2):
//   Stage 0 (0-5s):     RED_TONE only (intro)
//   Stage 1 (5-10s):    + SPATIAL_WARP (build)
//   Stage 2 (10-15s):   WAVE_DISTORTION only (verse - drops spatial)
//   Stage 3 (15-20s):   WAVE + RADIAL (pre-chorus)
//   Stage 4 (20-25s):   All 3 effects (chorus - full intensity!)
//   Stage 5 (25s+):     All 3 effects, sustained
//
// 🎚️ HYBRID MODE (Mode 2): Stages advance when EITHER:
//   - Time threshold reached (minimum duration), OR
//   - Strong bass hit detected (bass > BASS_TRIGGER_THRESHOLD)
//   Whichever comes LATER (prevents premature triggering in quiet intros)
//
// ============================================================

// --- AUTOMATION SETTINGS ---
#define AUTOMATION_MODE 1              // 0=Manual, 1=Time-based, 2=Audio-Smart (Hybrid) ⭐
#define BASS_TRIGGER_THRESHOLD 0.25    // Bass level to advance stage (0.0-1.0)
#define STAGE_MIN_DURATION 5.0         // Minimum seconds before stage can advance
#define ENABLE_BASS_ACCELERATION 1     // Allow bass hits to skip ahead (0=off, 1=on)

// --- MANUAL MODE TOGGLES (Only used when AUTOMATION_MODE = 0) ---
#define MANUAL_SPATIAL_WARP 0          // Manual control: Spatial warp
#define MANUAL_WAVE_DISTORTION 0       // Manual control: Wave distortion
#define MANUAL_RADIAL_PULSE 0          // Manual control: Radial pulse
// Note: RED_TONE_MODULATION is ALWAYS ON regardless of mode

// --- SPATIAL WARP (Global coordinate modulation) ---
#define SPATIAL_WARP_Z_STRENGTH 0.02
#define SPATIAL_WARP_W_STRENGTH 0.02
#define SPATIAL_WARP_Z_FREQUENCY 0.8
#define SPATIAL_WARP_W_FREQUENCY 0.8

// --- WAVE DISTORTION (Local spatial waves) ---
#define WAVE_FREQUENCY 0.01           // Number of waves across image (higher = more waves)
#define WAVE_SPEED 0.7               // Speed of wave animation
#define WAVE_BASS_STRENGTH 0.03       // How much bass affects waves
#define WAVE_MID_STRENGTH 0.0005        // How much mid affects waves
#define WAVE_TREBLE_STRENGTH 0.0005     // How much treble affects waves

// --- RADIAL PULSE (Center-based pulsing) ---
#define RADIAL_STRENGTH 0.02          // Strength of radial effect
#define RADIAL_FREQUENCY 1.2         // Speed of radial pulsing

// --- RED TONE MODULATION (Color-based oscilloscope effect) ---
#define RED_BASS_BRIGHTNESS 0.2      // How much bass affects red brightness (0.0 - 1.0)
#define RED_MID_BRIGHTNESS 0.1       // How much mid affects red brightness (0.0 - 1.0)
#define RED_TREBLE_BRIGHTNESS 0.1    // How much treble affects red brightness (0.0 - 1.0)
#define RED_DETECTION_THRESHOLD 0.07  // Minimum red intensity to detect (0.0 - 1.0)
#define RED_DETECTION_SHARPNESS 0.4  // Sharpness of red detection (higher = more selective)

// --- AUDIO SAMPLING ---
#define AUDIO_BASS_BOOST 2.0         // Amplify bass frequencies (1.0 - 10.0)
#define AUDIO_THRESHOLD 0.05         // Noise floor threshold (silence detection)

// ============================================================

// FFT macro - samples audio from iChannel0 (normalized coordinates for OneOffRender)
#define FFT(a) pow(texture(iChannel0, vec2(float(a) / 512.0, 0.0)).x, AUDIO_BASS_BOOST)

// ============================================================
// STAGE CALCULATION FUNCTION
// ============================================================
int calculateStage(float time, float bass_level) {{
    #if AUTOMATION_MODE == 0
        // Manual mode - no automatic progression
        return -1;
    #elif AUTOMATION_MODE == 1
        // Time-based mode - fixed intervals
        return int(time / STAGE_MIN_DURATION);
    #else
        // Audio-smart mode (Hybrid) - time OR bass triggers
        int time_stage = int(time / STAGE_MIN_DURATION);

        #if ENABLE_BASS_ACCELERATION
            // Check if bass hit is strong enough to advance
            // But only if we've been in current stage for at least 2 seconds
            float time_in_stage = mod(time, STAGE_MIN_DURATION);
            if (time_in_stage > 2.0 && bass_level > BASS_TRIGGER_THRESHOLD) {{
                // Bass hit detected - advance to next stage
                return time_stage + 1;
            }}
        #endif

        // Default: use time-based stage
        return time_stage;
    #endif
}}

